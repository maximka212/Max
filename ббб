<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>SYSTEM: SOLO LEVELING</title>
    <style>
        :root { --blue: #00d4ff; --red: #ff0055; --bg: #050507; }
        body { background: var(--bg); color: #fff; font-family: 'Helvetica Neue', sans-serif; margin: 0; padding: 20px; }
        .window { border: 2px solid var(--blue); background: rgba(0, 212, 255, 0.05); padding: 15px; border-radius: 10px; box-shadow: 0 0 20px rgba(0, 212, 255, 0.3); margin-bottom: 20px; position: relative; overflow: hidden; }
        .window::before { content: "SYSTEM INFO"; position: absolute; top: 0; right: 10px; font-size: 10px; color: var(--blue); opacity: 0.5; }
        .header { text-align: center; border-bottom: 1px solid var(--blue); margin-bottom: 15px; padding-bottom: 10px; font-weight: bold; letter-spacing: 2px; color: var(--blue); }
        .stat-row { display: flex; justify-content: space-between; margin: 15px 0; font-size: 1.1em; border-bottom: 1px solid rgba(255,255,255,0.1); padding-bottom: 5px; }
        .lvl-text { color: var(--blue); font-size: 1.5em; text-shadow: 0 0 10px var(--blue); }
        .exp-bar { width: 100%; height: 12px; background: #111; border-radius: 6px; border: 1px solid #333; margin: 10px 0; }
        .exp-fill { height: 100%; background: linear-gradient(90deg, #00d4ff, #0055ff); width: 0%; transition: width 0.8s ease; }
        .quest-box { border-left: 4px solid var(--red); background: rgba(255, 0, 85, 0.05); padding: 15px; margin-top: 20px; }
        .quest-title { color: var(--red); font-weight: bold; margin-bottom: 10px; }
        .btn { width: 100%; padding: 18px; background: var(--blue); border: none; color: #000; font-weight: bold; border-radius: 5px; margin-top: 20px; font-size: 1em; text-transform: uppercase; }
        .btn:active { transform: scale(0.98); opacity: 0.8; }
    </style>
</head>
<body>

<div class="window">
    <div class="header">СТАТУС ИГРОКА</div>
    <div class="stat-row">
        <span>УРОВЕНЬ: <span id="lvl" class="lvl-text">1</span></span>
        <span id="rank" style="color: #aaa;">РАНГ: E</span>
    </div>
    <div class="exp-bar"><div id="exp-fill" class="exp-fill"></div></div>
    <div style="text-align: right; font-size: 0.8em; color: var(--blue);">EXP: <span id="exp-val">0</span>/100</div>

    <div class="stat-row"><span>СИЛА (STR)</span> <span id="str">10</span></div>
    <div class="stat-row"><span>ВЫНОСЛ (VIT)</span> <span id="vit">10</span></div>
    <div class="stat-row"><span>ИНТЕЛЛЕКТ (INT)</span> <span id="int">10</span></div>
</div>

<div class="quest-box">
    <div class="quest-title">ЕЖЕДНЕВНЫЙ КВЕСТ</div>
    <div id="tasks" style="line-height: 1.6; font-size: 0.9em;">
        • Приседания: 100 раз<br>
        • Отжимания: 100 раз<br>
        • Пресс: 100 раз<br>
        • Бег: 10 км
    </div>
</div>

<button class="btn" onclick="gainExp()">Завершить тренировку</button>

<script>
    let stats = JSON.parse(localStorage.getItem('soloLevelingSave')) || { lvl: 1, exp: 0, str: 10, vit: 10, int: 10 };

    function updateUI() {
        document.getElementById('lvl').innerText = stats.lvl;
        document.getElementById('str').innerText = stats.str;
        document.getElementById('vit').innerText = stats.vit;
        document.getElementById('int').innerText = stats.int;
        document.getElementById('exp-val').innerText = stats.exp;
        document.getElementById('exp-fill').style.width = stats.exp + '%';
        
        let rank = 'E';
        if(stats.lvl > 10) rank = 'D';
        if(stats.lvl > 25) rank = 'C';
        if(stats.lvl > 50) rank = 'B';
        if(stats.lvl > 80) rank = 'A';
        if(stats.lvl >= 100) rank = 'S';
        document.getElementById('rank').innerText = 'РАНГ: ' + rank;

        localStorage.setItem('soloLevelingSave', JSON.stringify(stats));
    }

    function gainExp() {
        stats.exp += 20; // Даем 20 опыта за тренировку
        if (stats.exp >= 100) {
            stats.exp = 0;
            stats.lvl++;
            stats.str += 2;
            stats.vit += 1;
            stats.int += 1;
            alert("ВЫ ПОВЫСИЛИ УРОВЕНЬ!");
        }
        updateUI();
    }

    updateUI();
</script>

</body>
</html>
